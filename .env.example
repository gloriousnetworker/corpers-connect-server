# =============================================================
# CORPERS CONNECT — BACKEND ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.
# =============================================================

# ─── APP ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── DATABASE (PostgreSQL via Prisma) ────────────────────────
# Railway provides this automatically when you add a Postgres service.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/corpers_connect?schema=public

# ─── REDIS ───────────────────────────────────────────────────
# Railway provides this automatically when you add a Redis service.
# Format: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_64_CHAR_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── EMAIL (Resend) ──────────────────────────────────────────
# Get your API key at: https://resend.com → API Keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=Corpers Connect <noreply@corpers-connect.ng>

# ─── CLOUDINARY (Images & Videos) ───────────────────────────
# Get these from: https://cloudinary.com → Dashboard
# Free tier: 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── FIREBASE (Push Notifications) ──────────────────────────
# Path to your Firebase Admin SDK JSON file (relative to project root)
# The file corpers-connect-firebase-adminsdk.json is already at the root.
FIREBASE_SERVICE_ACCOUNT_PATH=./corpers-connect-firebase-adminsdk.json

# These values come directly from your Firebase Admin SDK JSON:
FIREBASE_PROJECT_ID=corpers-connect
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@corpers-connect.iam.gserviceaccount.com
# Copy the full private_key value from the JSON (include the -----BEGIN/END PRIVATE KEY----- lines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── PAYSTACK (Subscriptions & Payments) ────────────────────
# Get keys at: https://dashboard.paystack.com → Settings → API Keys
# Use TEST keys during development, LIVE keys for production
PAYSTACK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── AGORA (Voice & Video Calls) ─────────────────────────────
# Sign up at: https://agora.io → Console → Create Project
# Choose "Secured Mode (App ID + Token)"
# Free tier: 10,000 minutes/month
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ─── TERMII (SMS OTP) — DEFERRED, NOT NEEDED FOR MVP ─────────
# Sign up at: https://termii.com when SMS is needed
# TERMII_API_KEY=your_termii_api_key
# TERMII_SENDER_ID=CorpersConnect

# ─── NYSC INTEGRATION ────────────────────────────────────────
# Currently using mock data. When NYSC API is available, fill these in.
# NYSC_API_BASE_URL=https://api.nysc.gov.ng
# NYSC_API_KEY=your_nysc_api_key

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ─── BCRYPT ──────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
